{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/better-sqlite3/build/Release/better_sqlite3.node"
    }
  },
  "rewrites": [
    {
      "source": "/:path((?!api/)(?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
